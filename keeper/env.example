# ============================================================
# KEEPER ENVIRONMENT — copy to .env and fill in after deploy
# ============================================================

# --- Wallet ---
KEEPER_PRIVATE_KEY=0x...

# --- Alchemy ---
ALCHEMY_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_WSS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# --- Contract addresses (fill after deployment) ---
HOOK_CONTRACT=0x...
VAULT=0x...
ASSET_MANAGER=0x...
STRATEGY_MANAGER=0x...

# --- Whitelisted pairs (YOU control this list — keeper never goes outside it)
# Format: baseToken:quoteToken:fee:tickSpacing:poolAddress
# fee:        500=0.05%  3000=0.3%  10000=1%
# tickSpacing: 10        60         200
# poolAddress: the actual Uniswap v4 pool address (fill after deployment)
WHITELISTED_PAIRS=0xNOCK_ADDRESS:0xUSDC_ADDRESS:10000:200:0xPOOL_ADDRESS

# --- Range config ---
RANGE_WIDTH_BPS=1000

# --- Scheduler ---
UPDATE_INTERVAL_SECONDS=3600

# --- Migration filters (all must pass before migration is considered) ---
MIN_DAILY_VOLUME_USD=50000
MIN_LIQUIDITY_USD=100000
MIN_VOLUME_TVL_RATIO=0.3
MIN_POOL_AGE_DAYS=90

# Consecutive hourly readings that must all pass filters before migration.
# Prevents reacting to one-off volume spikes.
MIN_CONSECUTIVE_GOOD_READINGS=3

# --- Transaction config ---
DEADLINE_BUFFER_SECONDS=120
